# Copy to .env and fill in. .env is gitignored — never commit real creds.

# Basic-auth for the local proxy. Make these up (any user + a strong random pass);
# they become part of the YOUTUBE_PROXY URL you paste into Render.
PROXY_USER=wf
PROXY_PASS=change-me-to-a-long-random-string

# ngrok auth token from https://dashboard.ngrok.com/get-started/your-authtoken
# (free account). Required for the TCP tunnel.
NGROK_AUTHTOKEN=
