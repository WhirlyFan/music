# Copy to .env and fill in. .env is gitignored — never commit the auth key.

# Tailscale auth key from https://login.tailscale.com/admin/settings/keys
# (use the SAME Tailscale account the backend's TS_AUTHKEY uses, so they share a
# tailnet). A reusable key lets you bring this node up on any machine.
TS_AUTHKEY=

# Tailnet name for this exit node. Whatever you set here is what you put in the
# backend's TS_EXIT_NODE env on Render.
TS_HOSTNAME=music-home-exit
