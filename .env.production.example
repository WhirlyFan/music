# Copy to .env on your production host and replace every "CHANGE_ME" value.
# .env is git-ignored.
#
# Sanity checklist before going live:
#   1. DJANGO_SECRET_KEY is unique to this deploy (50+ random chars)
#   2. POSTGRES_PASSWORD + both DB roles use strong passwords
#   3. DJANGO_ALLOWED_HOSTS contains your actual domain(s)
#   4. DJANGO_CORS_ALLOWED_ORIGINS only lists frontends you trust
#   5. HATCHET_CLIENT_TOKEN is set (run `make hatchet-token` once, save here)
#   6. SENTRY_DSN is set if you want error reporting
#   7. TLS terminated upstream (Cloudflare / load balancer / Caddy)

# ---- Postgres ----
# These are the *superuser* credentials. The init.sql script creates app_user
# and app_admin roles separately — those are what Django actually uses.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=postgres

# Django connects as app_user (no BYPASSRLS — RLS policies enforced).
# Replace the password with something strong; update postgres/init.sql to
# match before first deploy.
DATABASE_URL=postgres://app_user:CHANGE_ME@db:5432/appdb

# Used by migrations + seed + management commands that need to cross owners.
DATABASE_URL_ADMIN=postgres://app_admin:CHANGE_ME@db:5432/appdb

# ---- Django ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_50_PLUS_CHAR_SECRET
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.prod

# Only list real, trusted origins. Leave empty if FE is same-origin via nginx.
DJANGO_CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ---- Frontend ----
# Same-origin via the in-stack nginx, so '/api' is correct.
VITE_API_BASE=/api

# ---- Hatchet ----
# First deploy: bring up `hatchet` alone, log into http://localhost:8888
# as admin@example.com / Admin123!! (change the password!!), mint a token,
# paste it here, then bring up the rest.
HATCHET_CLIENT_TOKEN=CHANGE_ME_FROM_HATCHET_UI
HATCHET_CLIENT_HOST_PORT=hatchet:7077
HATCHET_CLIENT_TLS_STRATEGY=none

# ---- Sentry ----
# Get a DSN at https://sentry.io (free tier). Leave blank to disable.
SENTRY_DSN=

# ---- Behind-a-proxy hint ----
# When Cloudflare / a load balancer terminates TLS, your origin only sees
# HTTP. Django needs to know the real scheme for secure cookies + redirects.
# config/settings/prod.py already sets SECURE_PROXY_SSL_HEADER, so a
# correctly-configured upstream (sending X-Forwarded-Proto: https) makes
# Django treat the request as HTTPS for cookies + SSL redirect.
