# Supply-chain hardening.

# Write EXACT versions (no ^/~) when running `pnpm add`, so a direct dep can't
# silently drift into a newer — possibly compromised — release. All current deps
# are already pinned exact in package.json; the lockfile pins the full transitive
# tree, and CI / Dockerfile / render.yaml all install with --frozen-lockfile.
save-exact=true

# Refuse packages published less than this ago — defends against grabbing a
# freshly-published malicious version before it's caught/yanked (the npm attack
# pattern). Tradeoff: you can't install a brand-new release until it "ages in";
# bump the window down temporarily if you genuinely need a fresh package.
minimum-release-age=7d
