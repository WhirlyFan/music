{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc -b && vite build",
    "tsr": "tsr generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "gen:api": "openapi-typescript http://localhost/api/schema/ -o src/lib/api/types.ts",
    "postinstall": "(cd $(git rev-parse --show-toplevel 2>/dev/null || pwd) && git config core.hooksPath .githooks 2>/dev/null || true)"
  },
  "dependencies": {
    "@github/webauthn-json": "2.1.1",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-form": "1.32.0",
    "@tanstack/react-query": "5.100.13",
    "@tanstack/react-router": "1.170.7",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tanstack/eslint-plugin-query": "5.100.14",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-cli": "1.167.9",
    "@tanstack/router-plugin": "1.168.10",
    "@types/babel__core": "7.20.5",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.14"
  }
}
