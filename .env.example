# Copy to .env and adjust. .env is git-ignored.

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Django connects as app_user (no BYPASSRLS — RLS policies are enforced).
DATABASE_URL=postgres://app_user:app_user@db:5432/appdb

# Used by migrations + seed + management commands that need to cross owners.
DATABASE_URL_ADMIN=postgres://app_admin:app_admin@db:5432/appdb

# ---- Django ----
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost

# Encryption key for sensitive MFA fields at rest (TOTP secrets etc.).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Dev key below is committed to the repo deliberately — it only protects
# local dev DBs, not real data. Generate a unique one for each deploy.
MFA_FIELD_ENCRYPTION_KEY=eNu83iHsGygVnWNzG97IFWzeLCLaLA4P9WKwcaw8VrA=

# Origin of the user-facing frontend. Used by allauth to build URLs in
# transactional emails (password reset link, signup confirmation). In
# prod set this to your real domain, e.g. https://app.yourdomain.com.
FRONTEND_ORIGIN=http://localhost

# ---- Frontend ----
VITE_API_BASE=/api/v1

# ---- Sentry (optional) ----
SENTRY_DSN=
